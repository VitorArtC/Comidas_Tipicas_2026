@page
@model ML_2025.Pages.TreinamentoModel
@{
    ViewData["Title"] = "Dados de Treinamento";
}

<div class="container mt-5">
    <h1 class="mb-4 text-white">Dados de Treinamento da IA</h1>
    <p class="text-white">Abaixo estão listados todos os dados utilizados para o treinamento do modelo (lidos do arquivo sentiment.csv).</p>

    <div class="table-responsive">
        <table class="table table-dark table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Texto (Comida)</th>
                    <th>Label (É Típica?)</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DadosTreinamento != null && Model.DadosTreinamento.Count > 0)
                {
                    foreach (var dado in Model.DadosTreinamento)
                    {
                        <tr>
                            <td>@dado.Text</td>
                            <td>
                                @if (dado.Label)
                                {
                                    <span class="badge bg-success">Sim</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Não</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="2" class="text-center text-muted">Nenhum dado de treinamento encontrado.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
