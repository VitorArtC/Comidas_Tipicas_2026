@page
@model PrivacyModel
@{
    ViewData["Title"] = "Participantes do Projeto";
}
<div class="participants-container">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <p class="page-subtitle">Conheça a equipe responsável pelo desenvolvimento deste projeto.</p>

    <div class="participants-grid">
        <div class="participant-card">
            <div class="avatar-wrapper">
                <img src="~/Imagens/vitor.png" alt="Vitor Arthur" class="participant-photo" />
            </div>
            <div class="participant-info">
                <h3 class="participant-name">Vitor Arthur</h3>
                <span class="participant-course">ADS</span>
            </div>
        </div>

        <div class="participant-card">
            <div class="avatar-wrapper">
                <img src="~/Imagens/roberth.png" alt="Roberth Kennedy" class="participant-photo" />
            </div>
            <div class="participant-info">
                <h3 class="participant-name">Roberth Kennedy</h3>
                <span class="participant-course">ADS</span>
            </div>
        </div>

        <div class="participant-card">
            <div class="avatar-wrapper">
                <img src="~/Imagens/arthur.png" alt="Arthur Oliveira" class="participant-photo" />
            </div>
            <div class="participant-info">
                <h3 class="participant-name">Arthur Oliveira</h3>
                <span class="participant-course">ADS</span>
            </div>
        </div>

        <div class="participant-card">
            <div class="avatar-wrapper">
                <img src="~/Imagens/manu.png" alt="Manu Kelry" class="participant-photo" onerror="this.src='https://ui-avatars.com/api/?name=Manu+Kelry&background=random&size=150'" />
            </div>
            <div class="participant-info">
                <h3 class="participant-name">Manu Kelry</h3>
                <span class="participant-course">ADS</span>
            </div>
        </div>
    </div>
</div>

<style>
    .participants-container {
        padding: 40px 20px;
        max-width: 1200px;
        margin: 0 auto;
        text-align: center;
        animation: fadeIn 0.8s ease-in-out;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 10px;
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        font-size: 1.1rem;
        color: var(--text-muted);
        margin-bottom: 50px;
    }

    .participants-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        justify-items: center;
    }

    .participant-card {
        background: var(--glass-bg, rgba(20, 20, 25, 0.6));
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border-color, rgba(255, 255, 255, 0.08));
        border-radius: 16px;
        padding: 30px 20px;
        width: 100%;
        max-width: 320px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .participant-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 100px;
        background: linear-gradient(135deg, var(--primary, #ff5e62) 0%, var(--secondary, #ff9966) 100%);
        z-index: 0;
        border-radius: 16px 16px 0 0;
        opacity: 0.85;
    }

    .participant-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px var(--primary-glow, rgba(255, 94, 98, 0.4));
        border-color: rgba(255, 94, 98, 0.3);
    }

    .avatar-wrapper {
        position: relative;
        z-index: 1;
        margin-bottom: 20px;
        margin-top: 20px;
    }

    .participant-photo {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid var(--bg-dark, #0a0a0f);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .participant-card:hover .participant-photo {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.6), 0 0 15px var(--primary-glow, rgba(255, 94, 98, 0.4));
    }

    .participant-info {
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .participant-name {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-main, #f8f9fa);
        margin: 0 0 8px 0;
    }

    .participant-course {
        display: inline-block;
        font-size: 0.875rem;
        font-weight: 600;
        color: #fff;
        background: linear-gradient(135deg, var(--primary, #ff5e62), var(--secondary, #ff9966));
        padding: 4px 14px;
        border-radius: 9999px;
        letter-spacing: 0.8px;
        box-shadow: 0 2px 10px var(--primary-glow, rgba(255, 94, 98, 0.4));
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
